# Alta Outbound Voice Agent — environment template
# Copy to .env and fill in real values LOCALLY. NEVER commit .env.
# This file: placeholders ONLY. No real keys, no card number (CLAUDE.md §5 / SEC1/LEAK1).

# --- Vapi voice platform ---
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# --- OpenAI (configured in Vapi platform; key also needed if used directly) ---
OPENAI_API_KEY=your_openai_api_key_here

# --- Cal.com booking ---
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_EVENT_TYPE_ID=your_calcom_event_type_id_here

# --- Webhook tunnel (public HTTPS URL Vapi will call; ngrok / Cloudflare / deployed host) ---
PUBLIC_WEBHOOK_URL=https://your-tunnel.example.com

# --- Consent allowlist (path to the untracked JSON file with consented numbers) ---
# The real allowlist is gitignored. Copy consent_allowlist.example.json → consent_allowlist.json and fill real numbers.
CONSENT_ALLOWLIST_PATH=consent_allowlist.json
